# =============================================================================
# BetVision AI — EXAMPLE environment file
# -----------------------------------------------------------------------------
# Copy to `.env` (`cp .env.example .env`) and fill with LOCAL values.
# Every value below is a PLACEHOLDER / EXAMPLE only — NEVER commit real secrets.
# Generate strong secrets with: `openssl rand -hex 32`
# =============================================================================

# --- Core ---------------------------------------------------------------------
NODE_ENV=development
# Default locale for i18n (EN/ES supported). See Feature Spec A.
DEFAULT_LOCALE=en
# Port the API listens on inside its container.
PORT=3000

# --- PostgreSQL ---------------------------------------------------------------
POSTGRES_USER=betvision
POSTGRES_PASSWORD=change_me_local_only
POSTGRES_DB=betvision
POSTGRES_PORT=5432
# Used by host-run tooling (Prisma migrate/seed) via localhost.
# Inside docker compose this is OVERRIDDEN to use the `postgres` service host,
# so you do not need to change it for the containers to talk to the DB.
DATABASE_URL=postgresql://betvision:change_me_local_only@localhost:5432/betvision?schema=public

# --- Redis --------------------------------------------------------------------
REDIS_PORT=6379
# Host tooling uses localhost; compose overrides this to the `redis` service host.
REDIS_URL=redis://localhost:6379

# --- Auth / JWT ---------------------------------------------------------------
# MUST be long random strings and DIFFERENT from each other. Example only:
JWT_ACCESS_SECRET=replace_with_openssl_rand_hex_32
JWT_REFRESH_SECRET=replace_with_a_DIFFERENT_openssl_rand_hex_32
JWT_ACCESS_TTL=900        # seconds (15m)
JWT_REFRESH_TTL=604800    # seconds (7d)

# --- Ports / URLs (host-side mappings used by docker-compose) -----------------
API_PORT=3000
WEB_PORT=3001
ADMINER_PORT=8080
# Server-to-server base URL for the API (compose overrides to http://api:3000).
API_URL=http://localhost:3000
# Browser-facing API base URL (baked into the web build; keep it host-reachable).
NEXT_PUBLIC_API_URL=http://localhost:3000

# --- LLM / AI provider (PLACEHOLDER) ------------------------------------------
# Anthropic Claude — used by the AI explanation/report pipeline (Phase 12).
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# --- External data providers (PLACEHOLDERS) -----------------------------------
# One key per capability behind the provider ports (Phase 7). Replace as needed.
SPORTS_DATA_API_KEY=replace_me
ODDS_API_KEY=replace_me
INJURIES_API_KEY=replace_me
LINEUPS_API_KEY=replace_me
REFEREE_API_KEY=replace_me
WEATHER_API_KEY=replace_me
